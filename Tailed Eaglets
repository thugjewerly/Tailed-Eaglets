<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tailed Eaglets — Esports</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;0,700;0,800;1,700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #080a0c;
    --dark: #0e1114;
    --card: #13171c;
    --border: #1e252e;
    --white: #f0f2f5;
    --grey: #8a9ab0;
    --accent: #c8d8f0;
    --glow: rgba(200,216,240,0.12);
    --sharp: #ffffff;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    overflow-x: hidden;
    cursor: crosshair;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.6;
  }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(200,216,240,0.06) 0%, transparent 70%),
      repeating-linear-gradient(0deg, transparent, transparent 59px, var(--border) 59px, var(--border) 60px),
      repeating-linear-gradient(90deg, transparent, transparent 59px, var(--border) 59px, var(--border) 60px);
    background-size: auto, 60px 60px, 60px 60px;
    opacity: 0.5;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 60% at 50% 100%, var(--black) 0%, transparent 70%);
  }

  nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 60px;
    border-bottom: 1px solid var(--border);
    background: rgba(8,10,12,0.7);
    backdrop-filter: blur(12px);
  }

  .nav-logo { display: flex; align-items: center; gap: 14px; }
  .nav-logo img { width: 44px; height: 44px; object-fit: contain; filter: brightness(1.1); }
  .nav-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sharp);
  }

  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--grey);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.3s;
  }
  .nav-links a:hover { color: var(--accent); }
  .nav-links a:hover::after { width: 100%; }

  .nav-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.68rem;
    color: var(--grey);
    border: 1px solid var(--border);
    padding: 6px 14px;
    letter-spacing: 0.15em;
  }

  .hero-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 40px 120px;
    gap: 32px;
  }

  .hero-eyebrow {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    color: var(--grey);
    text-transform: uppercase;
    animation: fadeUp 0.8s ease both;
  }

  .hero-logo-wrap {
    position: relative;
    animation: fadeUp 0.8s ease 0.15s both;
  }
  .hero-logo-wrap::before {
    content: '';
    position: absolute;
    inset: -40px;
    background: radial-gradient(circle, rgba(200,216,240,0.1) 0%, transparent 70%);
    animation: pulse 3s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }
  .hero-logo-wrap img {
    width: 200px; height: 200px;
    object-fit: contain;
    position: relative; z-index: 1;
    filter: drop-shadow(0 0 30px rgba(200,216,240,0.25));
  }

  .hero-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(4rem, 10vw, 9rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--sharp);
    animation: fadeUp 0.8s ease 0.3s both;
  }
  .hero-title span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(200,216,240,0.4);
    font-style: italic;
  }

  .hero-subtitle {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--grey);
    text-transform: uppercase;
    animation: fadeUp 0.8s ease 0.45s both;
  }

  .hero-stats {
    display: flex;
    gap: 60px;
    animation: fadeUp 0.8s ease 0.6s both;
  }
  .hero-stat { text-align: center; }
  .hero-stat-num {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    color: var(--sharp);
    line-height: 1;
  }
  .hero-stat-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: var(--grey);
    text-transform: uppercase;
    margin-top: 4px;
    white-space: nowrap;
  }
  .hero-stat-sep { width: 1px; background: var(--border); align-self: stretch; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeUp 1s ease 1s both;
    z-index: 6;
    pointer-events: none;
  }
  .scroll-hint span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--grey);
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollAnim 1.5s ease-in-out infinite;
  }
  @keyframes scrollAnim {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  section { padding: 100px 60px; max-width: 1300px; margin: 0 auto; }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--grey);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 24px; height: 1px;
    background: var(--accent);
  }

  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    text-transform: uppercase;
    line-height: 0.95;
    margin-bottom: 48px;
  }

  /* ─── ABOUT ─── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 60px;
    align-items: start;
  }
  .about-divider { background: var(--border); align-self: stretch; }
  .about-text p {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--grey);
    margin-bottom: 20px;
  }
  .about-text p strong { color: var(--white); font-weight: 600; }
  .about-right { display: flex; flex-direction: column; gap: 24px; }

  .fact-card {
    border: 1px solid var(--border);
    padding: 24px 28px;
    background: var(--card);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .fact-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .fact-card:hover { border-color: rgba(200,216,240,0.3); transform: translateX(4px); }
  .fact-card:hover::before { opacity: 1; }

  .fact-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--grey);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .fact-value {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--sharp);
    letter-spacing: 0.05em;
  }

  /* дисциплины badge */
  .disciplines {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }
  .disc-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    padding: 8px 14px;
    border: 1px solid var(--accent);
    color: var(--accent);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    white-space: nowrap;
  }
  .disc-badge.soon {
    border-color: var(--border);
    color: var(--grey);
  }
  .disc-soon-tag {
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    color: var(--grey);
    opacity: 0.7;
    flex-shrink: 0;
  }

  /* ─── ROSTER ─── */
  #roster { background: var(--dark); max-width: 100%; padding: 100px 0; }
  .roster-inner { max-width: 1300px; margin: 0 auto; padding: 0 60px; }

  .roster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2px;
    margin-top: 48px;
  }

  .player-card {
    position: relative;
    overflow: hidden;
    background: var(--card);
    aspect-ratio: 3/4;
    cursor: pointer;
  }
  .player-card img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s ease, filter 0.4s ease;
    filter: grayscale(20%);
  }
  .player-card:hover img { transform: scale(1.05); filter: grayscale(0%); }

  .player-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,10,12,0.95) 0%, rgba(8,10,12,0.3) 50%, transparent 100%);
    transition: background 0.3s;
  }
  .player-card:hover .player-card-overlay {
    background: linear-gradient(to top, rgba(8,10,12,0.98) 0%, rgba(8,10,12,0.4) 60%, transparent 100%);
  }

  .player-card-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 32px 28px;
    transform: translateY(8px);
    transition: transform 0.3s;
  }
  .player-card:hover .player-card-info { transform: translateY(0); }

  .player-role {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .player-alias {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: var(--sharp);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 4px;
  }
  .player-real-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: var(--grey);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s 0.05s, transform 0.3s 0.05s;
  }
  .player-card:hover .player-real-name { opacity: 1; transform: translateY(0); }

  .player-tag {
    display: inline-block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    border: 1px solid var(--border);
    padding: 4px 10px;
    color: var(--grey);
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.3s 0.1s;
  }
  .player-card:hover .player-tag { opacity: 1; }

  .player-number {
    position: absolute;
    top: 20px; right: 20px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 5rem;
    color: rgba(255,255,255,0.04);
    line-height: 1;
    pointer-events: none;
    transition: color 0.3s;
  }
  .player-card:hover .player-number { color: rgba(255,255,255,0.07); }

  /* captain badge */
  .captain-badge {
    position: absolute;
    top: 20px; left: 20px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: #f0c060;
    border: 1px solid #f0c060;
    padding: 4px 10px;
    text-transform: uppercase;
    background: rgba(240,192,96,0.08);
  }

  /* ─── SPONSORS ─── */
  #sponsors {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 60px;
    max-width: 100%;
  }
  .sponsors-inner { max-width: 1300px; margin: 0 auto; }
  .sponsors-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--border);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 36px;
  }
  .sponsors-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 60px;
    flex-wrap: wrap;
  }
  .sponsor-item {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    color: var(--border);
    text-transform: uppercase;
    transition: color 0.3s;
    cursor: default;
  }
  .sponsor-item:hover { color: var(--grey); }
  .sponsor-sep { width: 4px; height: 4px; background: var(--border); transform: rotate(45deg); }

  /* ─── FOOTER ─── */
  footer {
    padding: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 24px;
  }
  .footer-logo { display: flex; align-items: center; gap: 12px; }
  .footer-logo img { width: 32px; height: 32px; object-fit: contain; opacity: 0.5; transition: opacity 0.3s; }
  .footer-logo:hover img { opacity: 1; }
  .footer-logo-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--grey);
  }
  .footer-copy {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    color: var(--border);
  }

  .section-hr { border: none; border-top: 1px solid var(--border); max-width: 1300px; margin: 0 auto; }

  @media (max-width: 900px) {
    nav { padding: 20px 24px; }
    nav .nav-links { display: none; }
    section { padding: 70px 24px; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-divider { display: none; }
    .hero-stats { gap: 32px; }
    footer { padding: 40px 24px; flex-direction: column; text-align: center; }
    #sponsors { padding: 40px 24px; }
    #roster { padding: 70px 0; }
    .roster-inner { padding: 0 24px; }
  }
</style>
</head>
<body>

<div class="hero">
  <div class="hero-bg"></div>

  <nav>
    <div class="nav-logo">
      <img src="data:image/png;base64," alt="TE Logo">
      <span class="nav-name">Tailed Eaglets</span>
    </div>
    <ul class="nav-links">
      <li><a href="#about">О команде</a></li>
      <li><a href="#roster">Состав</a></li>
      <li><a href="#sponsors">Партнёры</a></li>
    </ul>
    <div class="nav-tag">ESPORTS // 2026</div>
  </nav>

  <div class="hero-content">
    <div class="hero-eyebrow">Киберспортивная команда</div>
    <div class="hero-logo-wrap">
      <img src="data:image/png;base64," alt="Tailed Eaglets Logo">
    </div>
    <h1 class="hero-title">
      Tailed
      <span>Eaglets</span>
    </h1>
    <p class="hero-subtitle">We hunt. We dominate. We rise.</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">T·E</div>
        <div class="hero-stat-label">Тег команды</div>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <div class="hero-stat-num">CS2</div>
        <div class="hero-stat-label">Основная игра</div>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <div class="hero-stat-num">2</div>
        <div class="hero-stat-label">Игрока в составе</div>
      </div>
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</div>

<!-- ABOUT -->
<section id="about">
  <div class="section-label">О команде</div>
  <h2 class="section-title">Орлы<br>расправляют<br>крылья</h2>
  <div class="about-grid">
    <div class="about-text">
      <p><strong>Tailed Eaglets</strong> — молодая и амбициозная киберспортивная команда, которая заявила о себе в мире профессионального гейминга.</p>
      <p>Название команды несёт в себе глубокий смысл: <strong>орлята с хвостом</strong> — символ молодости, силы и стремительного роста. Как орлята, покидающие гнездо, команда рвётся к вершинам соревновательного киберспорта.</p>
      <p>Под брендом <strong>TE</strong> объединились игроки с холодным расчётом, молниеносной реакцией и командным духом, способным сломить любого соперника.</p>
    </div>
    <div class="about-divider"></div>
    <div class="about-right">
      <div class="fact-card">
        <div class="fact-label">Дисциплины</div>
        <div class="disciplines">
          <div class="disc-badge">Counter-Strike 2</div>
          <div class="disc-badge soon">Dota 2 <span class="disc-soon-tag">СКОРО</span></div>
        </div>
      </div>
      <div class="fact-card">
        <div class="fact-label">Статус</div>
        <div class="fact-value">Активный состав</div>
      </div>
      <div class="fact-card">
        <div class="fact-label">Спонсоры</div>
        <div class="fact-value">Logitech G · Shell · ТЦК</div>
      </div>
      <div class="fact-card">
        <div class="fact-label">Девиз</div>
        <div class="fact-value">"We hunt. We rise."</div>
      </div>
    </div>
  </div>
</section>

<hr class="section-hr">

<!-- ROSTER -->
<div id="roster">
  <div class="roster-inner">
    <div class="section-label">Состав</div>
    <h2 class="section-title">Наши<br>игроки</h2>
  </div>
  <div class="roster-inner">
    <div class="roster-grid">

      <!-- Ты — игрок 1 (P2 фото) -->
      <div class="player-card">
        <img src="data:image/png;base64," alt="Player 1">
        <div class="player-card-overlay"></div>
        <div class="captain-badge">★ Captain</div>
        <div class="player-number">01</div>
        <div class="player-card-info">
          <div class="player-role">Entry Fragger · CS2</div>
          <div class="player-alias">thugjewerly</div>
          <div class="player-real-name">Tailed Eaglets</div>
          <div class="player-tag">TE · Активный</div>
        </div>
      </div>

      <!-- Игрок 2 (P1 фото) -->
      <div class="player-card">
        <img src="data:image/png;base64," alt="Player 2">
        <div class="player-card-overlay"></div>
        <div class="player-number">02</div>
        <div class="player-card-info">
          <div class="player-role">IGL · Support</div>
          <div class="player-alias">s4musenko</div>
          <div class="player-real-name">Tailed Eaglets</div>
          <div class="player-tag">TE · Активный</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- SPONSORS -->
<div id="sponsors">
  <div class="sponsors-inner">
    <div class="sponsors-label">Наши партнёры</div>
    <div class="sponsors-row">
      <div class="sponsor-item">Logitech G</div>
      <div class="sponsor-sep"></div>
